# DAdzy Website - Apache Configuration
RewriteEngine On

# Security
Options -Indexes

# Protect sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(sql|log|md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Error documents
ErrorDocument 404 /index.php
ErrorDocument 403 /index.php
